          "rawQuery": true,
          "rawSql": "SELECT\n  database_name,\n  username,\n  state,\n  EXTRACT(EPOCH FROM (NOW() - query_start)) as query_duration_seconds,\n  query,\n  CASE\n    WHEN state = 'idle in transaction' AND EXTRACT(EPOCH FROM (NOW() - query_start)) > 300 THEN '🔴 CRITICAL'\n    WHEN state = 'idle in transaction' THEN '🟠 WARNING'\n    WHEN state = 'active' AND EXTRACT(EPOCH FROM (NOW() - query_start)) > 3600 THEN '🔴 SLOW QUERY'\n    ELSE '🟢 NORMAL'\n  END as severity\nFROM metrics_pg_connections\nWHERE time > NOW() - INTERVAL '1 hour'\n  AND (state = 'idle in transaction' OR EXTRACT(EPOCH FROM (NOW() - query_start)) > 60)\nORDER BY query_duration_seconds DESC\nLIMIT 50",
